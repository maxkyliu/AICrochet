# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ─── Ravelry Scraper (Phase 2 — optional) ────────────────────────────────────
RAVELRY_USERNAME=your-ravelry-username
RAVELRY_API_KEY=your-ravelry-api-key

# ─── Database ────────────────────────────────────────────────────────────────
AICROCHET_DB=data/aicrochet.db

# ─── Vision Provider ─────────────────────────────────────────────────────────
# Which LLM provider to use for image analysis.
# Options: gemini (default), claude, ollama, agnes
VISION_PROVIDER=gemini

# ─── Required ────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
# ─── Gemini Model ────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash

# ─── Agnes AI (set VISION_PROVIDER=agnes to use) ─────────────────────────────
# OpenAI-compatible endpoint.
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_API_KEY=your-agnes-api-key-here
# AGNES_MODEL=agnes-2.0-flash

# ─── Ollama (set VISION_PROVIDER=ollama to use) ──────────────────────────────
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=llava

# ─── Profile Models ──────────────────────────────────────────────────────────
# Market prototypes (data/models/market_profiles.json, built with
# `python -m models.prototypes build`) are the preferred initial-profile
# source. Set to false to fall back to hardcoded profiles.
USE_MARKET_PROFILES=true
USE_LEARNED_MODEL=false
# Mesh-measurement shape blend: 0 = reference shape only (measured amplitude),
# 1 = raw measured shape. Applies to the post-3D measured recompile pass.
MESH_BLEND_ALPHA=0.5

# ─── Feedback / Retraining ───────────────────────────────────────────────────
RETRAIN_THRESHOLD=100

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Public-deployment guards ────────────────────────────────────────────────
# Per-IP rate limits (slowapi notation) and a global daily cap on generations
# (0 = unlimited). Set GENERATE_DAILY_LIMIT on any public deployment to bound
# vision-API spend.
GENERATE_RATE_LIMIT=5/minute
FEEDBACK_RATE_LIMIT=20/minute
GENERATE_DAILY_LIMIT=0
MAX_UPLOAD_MB=8
OUTPUT_TTL_HOURS=24

# (External GPL tools section removed by change direct-mesh-accuracy — the CP-dependent
#  seamless and refinement features were removed; mesh measurement runs in-process.)
